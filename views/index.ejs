<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Todo</title>
    <link href="/css/styles.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

</head>
<body>
    <%- include('../views/partials/header.ejs') %>
    <div class="container mainContainer">
        <div class="card mx-auto mainCard shadow-lg">
            <img src="/images/todoPhoto.jpg" class="card-img-top" alt="a photo of a notepad and pencil">
            <div class="card-body">
                <h5 class="card-title">TODO</h5>
                <p class="card-text mainCardText">
                <form action="" class="form-group">
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" placeholder="What needs done?" aria-label="Recipient's username" aria-describedby="button-addon2">
                        <button class="btn btn-outline-secondary" type="button" id="button-addon2">Submit</button>
                      </div>
                </form>
                </p>
            </div>
        </div>
    </div>


    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <%- include('../views/partials/footer.ejs') %>
</body>
</html>